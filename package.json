    "Developer",
    "Experience",
    "State",
    "State-management",
    "Data",
    "Data-management",
    "Reactive",
    "Reactive-state",
    "Reactive-adapter",
    "Reactive-agnostic",
    "Lightweight",
    "Zero-dependency",
    "Dependency-free",
    "Angular",
    "Signals"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
